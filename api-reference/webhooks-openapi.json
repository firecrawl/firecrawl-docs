                  "type": { "type": "string", "const": "batch_scrape.completed" },
                  "id": { "type": "string", "format": "uuid", "description": "The batch scrape job ID." },
                  "webhookId": { "type": "string", "format": "uuid", "description": "Unique identifier for this webhook delivery." },
                  "data": { "type": "array", "items": {}, "description": "Empty array. Retrieve results via `GET /batch/scrape/{id}`.", "default": [] },
