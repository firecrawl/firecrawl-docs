                "webhookId": "b2c3d4e5-0002-0000-0000-000000000000",
                "data": [
                  {
                    "markdown": "# Example Page\n\nThis is the page content.",
                    "metadata": {
                      "title": "Example Page",
                      "description": "An example page.",
                      "sourceURL": "https://example.com",
                      "statusCode": 200
                    }
                  }
                ],
                "metadata": {}
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Return any `2xx` status code to acknowledge receipt." }
        }
      }
    },
    "batchScrapeCompleted": {
      "post": {
        "summary": "Batch Scrape Completed",
        "description": "Fired when all URLs in a batch scrape have been processed. Use `GET /batch/scrape/{id}` to retrieve the full results.",
        "operationId": "batchScrapeCompleted",
        "tags": ["Batch Scrape"],
        "parameters": [
          { "$ref": "#/components/parameters/FirecrawlSignature" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
