                "success": false,
                "type": "agent.cancelled",
                "webhookId": "d4e5f6a7-0005-0000-0000-000000000000"
              },
              "schema": {
                "properties": {
                  "data": {
                    "items": {
                      "properties": {
                        "creditsUsed": {
                          "description": "Total de créditos consumidos antes do cancelamento.",
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "id": {
                    "description": "O ID do job do agente.",
                    "format": "uuid",
                    "type": "string"
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/WebhookMetadata"
                  },
                  "success": {
                    "const": false,
                    "description": "Sempre `false` para este evento.",
                    "type": "boolean"
                  },
                  "type": {
                    "const": "agent.cancelled",
                    "type": "string"
                  },
                  "webhookId": {
                    "description": "Identificador único desta entrega de webhook.",
                    "format": "uuid",
                    "type": "string"
                  }
                },
                "required": [
                  "success",
                  "type",
                  "id",
                  "webhookId",
                  "data"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Retorne qualquer código de status `2xx` para confirmar o recebimento."
          }
        },
        "summary": "Agente cancelado",
        "tags": [
          "Agent"
        ]
      }
    },
