  "components": {
    "parameters": {
      "FirecrawlSignature": {
        "name": "X-Firecrawl-Signature",
        "in": "header",
        "required": false,
        "description": "Assinatura HMAC-SHA256 do corpo bruto da requisição, formatada como `sha256=<hex>`. Presente quando um segredo HMAC estiver configurado nas [configurações da sua conta](https://www.firecrawl.dev/app/settings?tab=advanced). Consulte [Segurança de Webhooks](/webhooks/security) para detalhes sobre a verificação.",
        "schema": {
          "type": "string",
          "example": "sha256=abc123def456789..."
        }
      }
    },
    "schemas": {
      "WebhookMetadata": {
        "type": "object",
        "description": "O objeto de metadados personalizado que você forneceu na configuração do webhook. Ele é retornado em todas as entregas.",
        "additionalProperties": {
          "type": "string"
        }
      },
      "ScrapeDocument": {
        "type": "object",
        "description": "Um documento de página extraída. Tem a mesma estrutura do objeto `data` nas respostas de scrape.",
        "properties": {
          "markdown": {
            "type": "string",
            "description": "O conteúdo da página convertido em Markdown."
          },
          "html": {
            "type": "string",
            "description": "Conteúdo HTML limpo da página."
          },
          "rawHtml": {
            "type": "string",
            "description": "HTML original antes de qualquer processamento."
          },
          "links": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Links de saída descobertos na página."
          },
          "screenshot": {
            "type": "string",
            "description": "Captura de tela codificada em Base64, se o formato `screenshot` tiver sido solicitado."
          },
          "metadata": {
            "type": "object",
            "description": "Metadados da página.",
            "properties": {
              "title": {
                "type": "string",
                "description": "O `<title>` da página."
              },
              "description": {
                "type": "string",
                "description": "A descrição meta."
              },
              "sourceURL": {
                "type": "string",
                "description": "A URL que foi extraída."
              },
              "statusCode": {
                "type": "integer",
                "description": "Código de status HTTP da resposta."
              }
            }
          }
        }
      }
    }
  }
}
