  "components": {
    "parameters": {
      "FirecrawlSignature": {
        "name": "X-Firecrawl-Signature",
        "in": "header",
        "required": false,
        "description": "Firma HMAC-SHA256 del cuerpo sin procesar de la solicitud, con el formato `sha256=<hex>`. Está presente cuando se configura un secreto HMAC en la [configuración de tu cuenta](https://www.firecrawl.dev/app/settings?tab=advanced). Consulta [Seguridad de webhooks](/webhooks/security) para obtener más detalles sobre la verificación.",
        "schema": {
          "type": "string",
          "example": "sha256=abc123def456789..."
        }
      }
    },
    "schemas": {
      "WebhookMetadata": {
        "type": "object",
        "description": "El objeto de metadatos personalizado que proporcionaste en la configuración del webhook. Se devuelve en cada entrega.",
        "additionalProperties": {
          "type": "string"
        }
      },
      "ScrapeDocument": {
        "type": "object",
        "description": "Un documento de una página extraída. Tiene la misma estructura que el objeto `data` en las respuestas de scrape.",
        "properties": {
          "markdown": {
            "type": "string",
            "description": "El contenido de la página convertido a Markdown."
          },
          "html": {
            "type": "string",
            "description": "Contenido HTML depurado de la página."
