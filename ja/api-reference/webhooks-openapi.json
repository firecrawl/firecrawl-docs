                "webhookId": "d4e5f6a7-0003-0000-0000-000000000000"
              },
              "schema": {
                "properties": {
                  "data": {
                    "items": {
                      "properties": {
                        "creditsUsed": {
                          "description": "エージェント実行全体で消費された合計クレジット数です。",
                          "type": "number"
                        },
                        "data": {
                          "additionalProperties": true,
                          "description": "エージェントによって抽出された構造化データです。スキーマが指定されている場合は、そのスキーマに一致します。",
                          "type": "object"
                        }
                      },
                      "type": "object"
                    },
                    "type": "array"
                  },
                  "id": {
                    "description": "エージェントジョブの ID。",
                    "format": "uuid",
                    "type": "string"
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/WebhookMetadata"
                  },
                  "success": {
                    "const": true,
                    "type": "boolean"
                  },
                  "type": {
                    "const": "agent.completed",
                    "type": "string"
                  },
                  "webhookId": {
                    "description": "この webhook 配信の一意の識別子。",
                    "format": "uuid",
                    "type": "string"
                  }
                },
                "required": [
                  "success",
                  "type",
                  "id",
                  "webhookId",
                  "data"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "受信を確認するには、任意の`2xx`ステータスコードを返してください。"
